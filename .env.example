# ===========================
# DineFlow - Environment Variables
# ===========================
# Copy this file as .env.local and fill in your values.

# Database (Required)
# Use Vercel Postgres or any PostgreSQL provider (Neon, Supabase, Railway, etc.)
# Example (Vercel Postgres): postgresql://user:password@host:5432/database?sslmode=require
# Example (Neon): postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/dineflow?sslmode=require"
DIRECT_URL="postgresql://user:password@localhost:5432/dineflow?sslmode=require"

# Vercel Postgres sets these automatically — no need to set manually on Vercel.
# For local dev, DATABASE_URL and DIRECT_URL can be the same.

# Application URL (Optional — Vercel sets this automatically)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
